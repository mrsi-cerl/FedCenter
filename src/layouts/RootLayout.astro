---
import Banner from "../components/Banner.astro";
import "../components/uswds/css/styles.css";
import Menu from "../components/Menu.astro";
import Sidebar from "../components/Sidebar.astro";
import Identifier from "../components/Identifier.astro";
import BreadCrumb from "../components/BreadCrumb.astro";
import ProgramAreaSidebar from "../components/ProgramAreaSidebar.astro";
import FacilityRegulatoryTourSidebar from "../components/FacilityRegulatoryTourSidebar.astro";
import { sideBarConstants } from "../constants";
import SidePageNavigation from "@/components/SidePageNavigation.astro";

const { pageTitle, showBreadcrumb = false } = Astro.props;
const { sideBarItems } = Astro.props;
// console.log("sbi: ", sideBarItems);
---

<html lang="en">
  <head>
    <script
      src={`${import.meta.env.BASE_URL}uswds/js/uswds-init.min.js`}
      is:inline
      defer></script>
    <script
      src={`${import.meta.env.BASE_URL}uswds/js/uswds.min.js`}
      is:inline
      defer></script>

    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href=`${import.meta.env.BASE_URL}favicon.svg`
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header>
      <Banner />
      <Menu />
    </header>
    <div class="width-widescreen margin-x-auto margin-top-4">
      <main id="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>
<Identifier />
