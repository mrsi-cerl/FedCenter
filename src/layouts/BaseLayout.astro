---
import Banner from "../components/Banner.astro";
import "../components/uswds/css/styles.css";
import Menu from "../components/Menu.astro";
import Sidebar from "../components/Sidebar.astro";
import Identifier from "../components/Identifier.astro";
import BreadCrumb from "../components/BreadCrumb.astro";
import ProgramAreaSidebar from "../components/ProgramAreaSidebar.astro";
import FacilityRegulatoryTourSidebar from "../components/FacilityRegulatoryTourSidebar.astro";
import { sideBarConstants } from "../constants";
import AnnouncementsSidebar from "@/components/AnnouncementsSidebar.astro";

const { pageTitle, showBreadcrumb = false } = Astro.props;
const { sideBarItems } = Astro.props;
// console.log("sbi: ", sideBarItems);
---

<html lang="en">
  <head>
    <script
      src={`${import.meta.env.BASE_URL}uswds/js/uswds-init.min.js`}
      is:inline
      defer></script>
    <script
      src={`${import.meta.env.BASE_URL}uswds/js/uswds.min.js`}
      is:inline
      defer></script>

    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href=`${import.meta.env.BASE_URL}favicon.svg`
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header>
      <Banner />
      <Menu />
    </header>
    <div class="widescreen margin-x-auto margin-top-4">
      {
        sideBarItems ? (
          //if there is a sidebar, we want to split the page into two sections
          <div class="grid-container">
            <div class="grid-row grid-gap">
              <div class="usa-layout-docs__sidenav desktop:grid-col-2">
                {/* <Sidebar sideBarItems={sideBarItems} />  */}
                {sideBarItems === sideBarConstants.ProgramArea && (
                  <ProgramAreaSidebar />
                )}
                {sideBarItems === sideBarConstants.FacilityTour && (
                  <FacilityRegulatoryTourSidebar />
                )}
                {sideBarItems === sideBarConstants.Announcements && (
                  <AnnouncementsSidebar />
                )}
              </div>
              <main class="desktop:grid-col-8" id="main-content">
                {showBreadcrumb && <BreadCrumb />}
                <h1>{pageTitle}</h1>
                <slot />
              </main>
              <div class="usa-layout-docs__sidenav desktop:grid-col-2">
                <ProgramAreaSidebar />
              </div>
            </div>
          </div>
        ) : (
          //if there is no sidebar, use the "entire" width of the page
          <main id="main-content">
            {showBreadcrumb && <BreadCrumb />}
            <h1>{pageTitle}</h1>
            <slot />
          </main>
        )
      }
    </div>
    <Identifier />
  </body>
</html>
