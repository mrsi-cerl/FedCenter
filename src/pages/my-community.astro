---
import Accordian from "../components/Accordian.astro";
import Card from "../components/Card.astro";
import SidePageNavigation from "../components/SidePageNavigation.astro";
import SummaryBox from "../components/SummaryBox.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "My Community";

// TODO: get posts for each question on this page
---

<BaseLayout pageTitle={pageTitle}>
  <SidePageNavigation>
    <div class="usa-prose">
      <p>
        The My Community / My Facility page provides access to the numerous data
        systems which contain information about issues such as: your compliance
        record, the permits you have, the wastes generated by your facility and
        your neighbors, the status of your watersheds, air monitoring data, and
        population statistics.
      </p>
    </div>
    <Accordian
      title="How Do I Find Environmental Information About My Community?"
    />
    <Accordian title="Violations/Enforcement Actions At Your Facility" />
    <Accordian title="Does Your Facility Have Any Sources of Air Emissions?" />
    <Accordian title="Is Your Facility a Cleanup Site?" />
    <Accordian title="Does Your Facility Generate Hazardous Waste?" />
    <Accordian title="Does Your Facility Have Any Wastewater Permits?" />
    <Accordian title="Does Your Facility Treat Drinking Water?" />
    <Accordian
      title="How Do I Find Multi-media Environmental Information About My Facility?"
    />
    <Accordian
      title="Where Do I Find Information On EPA Federal Facility Programs?"
    />
    <Accordian title="How Can I Prepare For An Emergency?" />
    <Accordian title="What Recycling Services Are Available To My Facility?" />
    <Accordian title=`What Is "Federal Real Property"` />
    <Accordian
      title="What Endangered/Threatened Species Might Be In My Area?"
    />
    <Accordian
      title="Where Are Treatment, Storage and Disposal Facilities Located Near Me?"
    />
  </SidePageNavigation>
</BaseLayout>
