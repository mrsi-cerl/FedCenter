---
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import SummaryBox from "../components/SummaryBox.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sideBarConstants } from "@/constants";

const pageTitle = "Welcome to FedCenter";

const announcements = await getCollection("programPost", ({ data }) => {
  return data.programArea === "Acquisition";
});
---

<BaseLayout pageTitle={pageTitle} sideBarItems={sideBarConstants.ProgramArea}>
  <div>
    <p class="font-body-md">
      <b>FedCenter.gov </b> is the Federal government's home for comprehensive environmental
      stewardship and compliance assistance information for Federal facility managers
      and their agencies.
    </p>
  </div>
  <ul class="usa-card-group">
    <Card
      cardTitle="What's New"
      buttonTitle="Find Out"
      media=`${import.meta.env.BASE_URL}woman-alone-nature-using-digital-tablet-with-entertainment-application-screen-internet-c.jpg`
      size="4"
      link="whats-new"
    >
      <p>
        Find out what's been recently posted on FedCenter with this daily log of
        all information added or updated within the last 30 days.
      </p>
    </Card>
    <Card
      cardTitle="Regulatory Watch"
      buttonTitle="Track Now"
      media=`${import.meta.env.BASE_URL}man-reading-book-education-academic-learning-exam-concept.jpg`
      size="4"
    >
      <p>
        Your source for monitoring and tracking proposed and final regulatory
        information.
      </p>
    </Card>
    <Card
      cardTitle="EPA Compliance and Enforcement Center"
      buttonTitle="Learn More"
      media=`${import.meta.env.BASE_URL}epa-logo-ss-jt-250312_1741817192677_hpMain_16x9_992.jpg`
      size="4"
    >
      <p>
        EPA's current focus on important compliance and enforcement issues
        facing federal facilities today.
      </p>
    </Card>
  </ul>
  <div>
    <h2>Featured Items</h2>
    <ul class="usa-list full-length-list">
      <li>
        <a class="usa-link" href="javascript:void(0);"
          >Facility Regulatory Tour</a
        >
        <p>
          Take a tour of the buildings and activities commonly found at federal
          facilities and find out what regulations apply and where.
        </p>
      </li>
      <li>
        <a class="usa-link" href="javascript:void(0);"
          >What About My Community and Facility?</a
        >
        <p>
          Access the numerous data systems which contain information about
          issues such as: your compliance record, the permits you have, the
          wastes generated by your facility and your neighbors, the status of
          your watersheds, air monitoring data, and population statistics.
        </p>
      </li>
      <li>
        <a class="usa-link" href="javascript:void(0);"
          >CPTrack - Compliance Tracker</a
        >
        <p>
          Web-based application used by multiple Federal agencies to document
          findings of environmental or safety noncompliance and the actions
          taken to correct noncompliance. Additionally, CPTrack™ is used to
          document activities with potential environmental/safety impact at
          individual Federal facilities.
        </p>
      </li>
      <li>
        <a class="usa-link" href="javascript:void(0);">List Builder</a>
        <p>
          A federal agency sponsored tool that uses the TEAM guides to build
          custom checklists and compare requirements across jurisdictions.
        </p>
      </li>
    </ul>
  </div>
</BaseLayout>
